# Copy this file to `.env` (same directory) and fill in your key.
# Required for the Summarize button, which calls Claude Haiku to generate a
# short title/custom_name for the session.

ANTHROPIC_API_KEY=sk-ant-...

# When true, the server runs reconcile on startup to embed any new/changed
# sessions into the local vector index. Default false — call POST /api/index/reconcile manually until you trust it.
AUTO_RECONCILE=false
